# BTL runtime — get your key at https://runtime.badtheorylabs.com (free $5 signup credit)
GATEWAY_API_KEY=

# Optional overrides
BTL_BASE_URL=https://api.badtheorylabs.com/v1

# Block-explorer key — lets "audit by address" fetch a contract's REAL verified
# source (or bytecode) from chain instead of relying on model memory. Free key
# at https://etherscan.io/apis. Etherscan's V2 endpoint is multichain.
ETHERSCAN_API_KEY=
# Which chain to resolve addresses on (1=Ethereum, 8453=Base, 42161=Arbitrum, …)
FLEX_CHAIN_ID=1

# Comma-separated auditor models (diverse providers = the whole point).
# Note: bare claude-* slugs are Anthropic-native (/v1/messages only) and won't
# work on /v1/chat/completions — use OpenAI-compatible routes like these.
FLEX_AUDITORS=gpt-5-5,gemini-2.5-pro,deepseek-v4-pro

# Referee model that clusters findings across auditors (a 4th, neutral family).
# For a faster/cheaper (slightly noisier) demo, use gpt-4.1,gemini-2.5-flash,mistral-large
FLEX_REFEREE=qwen3-max

# Demo-safety: set to 1 to force mock mode (works with no credits / offline).
FLEX_FORCE_MOCK=0
